2. Trigger to Convert Name into Uppercase
CREATE OR REPLACE TRIGGER emp2_capital_trg
BEFORE INSERT OR UPDATE ON emp2
FOR EACH ROW
BEGIN
    :NEW.name := UPPER(:NEW.name);
END;
/

